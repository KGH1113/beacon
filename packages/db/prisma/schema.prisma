generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Share {
  id            String    @id @default(cuid())
  token         String    @unique
  filePath      String
  fileName      String
  sizeBytes     BigInt?
  previewKind   String?
  previewStatus String    @default("unavailable")
  thumbnailPath String?
  streamPath    String?
  textPreviewPath String?
  downloadCount Int       @default(0)
  revokedAt     DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
