{
  "name": "beacon",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev --parallel --filter=@beacon/panel --filter=@beacon/daemon",
    "dev:panel": "bun run --filter @beacon/panel dev",
    "dev:daemon": "bun run --filter @beacon/daemon dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.2",
    "bun-types": "^1.3.11",
    "shadcn": "4.4.0",
    "turbo": "^2.0.14",
    "typescript": "^5.8.3"
  }
}
