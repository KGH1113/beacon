BEACON_APP_PASSWORD=changeme
BEACON_SESSION_SECRET=change-me-session-secret
BEACON_STREAM_TOKEN_SECRET=change-me-stream-secret
BEACON_PANEL_URL=http://localhost:3000
BEACON_DAEMON_URL=http://127.0.0.1:7300
# Browser-reachable daemon URL. On the homelab, prefer the Tailscale MagicDNS host.
NEXT_PUBLIC_DAEMON_BASE_URL=http://kgh:7300
# Public download URL exposed by Tailscale Funnel.
NEXT_PUBLIC_SHARE_BASE_URL=https://kgh.tail234c02.ts.net
BEACON_DAEMON_HOST=0.0.0.0
BEACON_DAEMON_PORT=7300
# Bun's default request body cap is 128MB. Beacon keeps upload size uncapped at the app level.
BEACON_DAEMON_MAX_REQUEST_BODY_SIZE_BYTES=9007199254740991
BEACON_SHARE_HOST=127.0.0.1
BEACON_SHARE_PORT=7301
BEACON_DATABASE_PATH=./data/beacon.sqlite
BEACON_CONFIG_DIR=./config
