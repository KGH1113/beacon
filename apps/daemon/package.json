{
  "name": "@beacon/daemon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "start": "bun run ./src/index.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@beacon/config": "workspace:*",
    "@beacon/db": "workspace:*",
    "@beacon/shared": "workspace:*",
    "@elysiajs/cors": "^1.1.1",
    "@types/dockerode": "4.0.1",
    "dockerode": "5.0.0",
    "elysia": "^1.1.26",
    "sharp": "0.34.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2"
  }
}
